# ==============================================================================
# BILLBUDDY ENVIRONMENT VARIABLES TEMPLATE (.env.example)
# ==============================================================================
# Instructions: Copy this file to '.env' and fill in the values before starting the backend.
# Do not commit '.env' with sensitive secrets to version control.

# ------------------------------------------------------------------------------
# Server Configuration
# ------------------------------------------------------------------------------
# Service: FastAPI Server
# Purpose: Port number that the local FastAPI server will listen on.
# Where to get: Customize this to any local port (default is usually 8000).
PORT=

# ------------------------------------------------------------------------------
# Firebase Config (Database & Audit Logging)
# ------------------------------------------------------------------------------
# Service: Google Firebase Firestore
# Purpose: Project ID for your Firebase project used to access Firestore database.
# Where to get: Create a project in Firebase Console (https://console.firebase.google.com/).
FIREBASE_PROJECT_ID=

# Service: Google Firebase Service Account Key
# Purpose: Absolute or relative file path to the Service Account JSON credentials file.
# Where to get: Firebase Console -> Project Settings -> Service Accounts -> Generate New Private Key.
FIREBASE_CREDENTIALS_JSON_PATH=

# ------------------------------------------------------------------------------
# BBPS Integration Config (Bill Fetch & Pay)
# ------------------------------------------------------------------------------
# Service: Eko.in BBPS API Gateway
# Purpose: API key for authentication with the Eko.in sandbox.
# Where to get: Sign up as a developer at Eko.in (https://eko.in/) and fetch credentials from developer panel.
EKO_BBPS_API_KEY=

# Service: Eko.in BBPS API Gateway
# Purpose: Unique Developer ID/Partner ID assigned to your account.
# Where to get: Assigned upon account setup in the Eko.in sandbox dashboard.
EKO_BBPS_DEVELOPER_ID=

# ------------------------------------------------------------------------------
# Payment mandate Config (Razorpay UPI Autopay)
# ------------------------------------------------------------------------------
# Service: Razorpay API Gateway
# Purpose: Key ID for authenticating requests to Razorpay's API to initiate UPI mandate creation and recurring charges.
# Where to get: Create a Razorpay account, enable Sandbox mode, and generate API keys (https://razorpay.com/).
RAZORPAY_KEY_ID=

# Service: Razorpay API Gateway
# Purpose: Secret key corresponding to the Razorpay Key ID.
# Where to get: Generated along with the Razorpay Key ID in the dashboard settings.
RAZORPAY_KEY_SECRET=

# ------------------------------------------------------------------------------
# WhatsApp Notifications Config (Twilio)
# ------------------------------------------------------------------------------
# Service: Twilio WhatsApp API
# Purpose: Account SID for Twilio authentication.
# Where to get: Create a Twilio account (https://www.twilio.com/try-twilio) and copy SID from dashboard homepage.
TWILIO_ACCOUNT_SID=

# Service: Twilio WhatsApp API
# Purpose: Auth Token matching your Twilio Account SID.
# Where to get: Found on your Twilio Console home dashboard under Account Info.
TWILIO_AUTH_TOKEN=

# Service: Twilio WhatsApp API
# Purpose: The WhatsApp-enabled sender phone number or Twilio Sandbox number.
# Where to get: Twilio Console -> Messaging -> Try it Out -> Send a WhatsApp Message (format: whatsapp:+14155238886).
TWILIO_WHATSAPP_NUMBER=

# ------------------------------------------------------------------------------
# AI Agent Language Translation & Risk Assessment Config
# ------------------------------------------------------------------------------
# Service: Google AI Studio (Gemini API)
# Purpose: API key to run translation / voice formatting LLM prompts.
# Where to get: Go to Google AI Studio (https://aistudio.google.com/) and click "Get API Key".
GEMINI_API_KEY=

# Service: Anthropic API (Optional Alternative)
# Purpose: API key to run Claude models (such as Claude 3.5 Sonnet) for Risk Agent checks.
# Where to get: Sign up on Anthropic Developer Console (https://platform.openai.com/ or https://console.anthropic.com/).
ANTHROPIC_API_KEY=
